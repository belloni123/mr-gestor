# Copy to .env.local for local development only.
# Never commit real .env files.

DATABASE_URL="postgresql://mr_gestor:CHANGE_ME@localhost:5432/mr_gestor?schema=public"

# Generate with: npm run security:secrets
SESSION_SECRET="CHANGE_ME_MINIMUM_32_CHARS"
APP_ENCRYPTION_KEY="CHANGE_ME_BASE64_32_BYTES"

# Public app URL used by future callbacks/webhooks.
APP_URL="https://gestao.nofrontscale.com.br"

# Initial bootstrap users. Use strong temporary passwords and rotate after first login.
BOOTSTRAP_SUPER_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_SUPER_ADMIN_NAME="Super Admin"
BOOTSTRAP_SUPER_ADMIN_PASSWORD="CHANGE_ME_STRONG_TEMP_PASSWORD"

BOOTSTRAP_EDITOR_EMAIL="editor@example.com"
BOOTSTRAP_EDITOR_NAME="Editor"
BOOTSTRAP_EDITOR_PASSWORD="CHANGE_ME_STRONG_TEMP_PASSWORD"
BOOTSTRAP_EDITOR_COMPANIES="b16,maestro"
